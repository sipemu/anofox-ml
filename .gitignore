/target
**/*.rs.bk
# Cargo.lock is checked in: the workspace ships a cdylib (rustml-python)
# whose build needs to be deterministic, and CI needs the same resolution
# as local development to avoid version-skew failures.

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# Jupyter
.ipynb_checkpoints/

# IDE
.idea/
.vscode/
*.swp
*.swo
